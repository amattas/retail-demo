	/// Stored daily conversion rate from the source table; prefer the recomputed [Campaign Conversion Rate] measure for aggregation across days.
	column 'Conversion Rate (Stored)'
		dataType: double
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 374ff2be-1ec3-454f-aa26-2ae31c1adb23
		sourceLineageTag: conversion_rate
		summarizeBy: none
		sourceColumn: conversion_rate

