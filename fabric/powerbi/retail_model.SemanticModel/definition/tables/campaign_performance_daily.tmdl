table campaign_performance_daily
	lineageTag: 7d488d7d-c3f2-4225-aa21-598ced6cae84
	sourceLineageTag: [au].[campaign_performance_daily]

	/// Total campaign spend, recomputed from cents.
	measure 'Campaign Spend' = DIVIDE(SUM('campaign_performance_daily'[Spend Cents]), 100, 0)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Campaign Performance\Spend
		lineageTag: 2bf946cc-6650-486b-a4c6-fbb17039efdd

	/// Total campaign impressions.
	measure 'Campaign Impressions' = SUM('campaign_performance_daily'[Impressions])
		formatString: #,0
		displayFolder: Campaign Performance\Reach
		lineageTag: 8f0fb83f-f454-4be7-ad97-cf440a73db48

	/// Total campaign conversions.
	measure 'Campaign Conversions' = SUM('campaign_performance_daily'[Conversions])
		formatString: #,0
		displayFolder: Campaign Performance\Conversions
		lineageTag: 18e1d027-ca59-4508-9c24-31c29f3072e1

	/// Total attributed revenue driven by campaigns, recomputed from cents.
	measure 'Campaign Attributed Revenue' = DIVIDE(SUM('campaign_performance_daily'[Attributed Revenue Cents]), 100, 0)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Campaign Performance\Revenue
		lineageTag: 4e5d5657-4b1e-4edd-9530-4000208df673

	/// Conversions per impression, recomputed from summed counts rather than averaging the stored daily rate.
	measure 'Campaign Conversion Rate' = DIVIDE([Campaign Conversions], [Campaign Impressions], 0)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Campaign Performance\Efficiency
		lineageTag: a0efeb81-311d-4881-b58a-cc6a865fa165

	/// Return on ad spend, recomputed from summed attributed revenue and spend cents rather than averaging the stored daily ratio.
	measure 'Campaign ROAS' = DIVIDE([Campaign Attributed Revenue], [Campaign Spend], 0)
		formatString: #,0.00
		displayFolder: Campaign Performance\Efficiency
		lineageTag: a1ff8e1a-9d8d-4594-b3bb-c28a3feb4b4f

