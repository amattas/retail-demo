table 'Dwell Predictions'
	lineageTag: a6000006-0000-0000-0000-000000000000
	sourceLineageTag: [au].[dwell_predictions]

	measure 'Avg Predicted Dwell' = AVERAGE('Dwell Predictions'[Predicted Dwell Minutes])
		formatString: #,0.0
		lineageTag: a6000006-0001-0001-0001-000000000001

	measure 'Avg Prediction Error' = AVERAGE(ABS('Dwell Predictions'[Prediction Error]))
		formatString: #,0.0
		lineageTag: a6000006-0001-0001-0001-000000000002

	measure 'Shipments Outside Band' = CALCULATE(COUNTROWS('Dwell Predictions'), OR('Dwell Predictions'[Dwell Minutes] > 'Dwell Predictions'[Upper Bound Minutes], 'Dwell Predictions'[Dwell Minutes] < 'Dwell Predictions'[Lower Bound Minutes]))
		formatString: #,0
		lineageTag: a6000006-0001-0001-0001-000000000003

	column 'Shipment ID'
		dataType: string
		lineageTag: a6000006-0002-0002-0002-000000000001
		sourceLineageTag: shipment_id
		summarizeBy: none
		sourceColumn: shipment_id

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Arrived TS'
		dataType: dateTime
		formatString: General Date
		lineageTag: a6000006-0002-0002-0002-000000000002
		sourceLineageTag: arrived_ts
		summarizeBy: none
		sourceColumn: arrived_ts

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Departed TS'
		dataType: dateTime
		formatString: General Date
		lineageTag: a6000006-0002-0002-0002-000000000003
