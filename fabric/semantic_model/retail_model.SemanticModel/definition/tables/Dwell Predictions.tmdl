		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Location Type'
		dataType: string
		lineageTag: a6000006-0002-0002-0002-000000000004
		sourceLineageTag: location_type
		summarizeBy: none
		sourceColumn: location_type

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Arrival Hour'
		dataType: int64
		formatString: 0
		lineageTag: a6000006-0002-0002-0002-000000000005
		sourceLineageTag: arrival_hour
		summarizeBy: none
		sourceColumn: arrival_hour

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Arrival Day of Week'
		dataType: int64
		formatString: 0
		lineageTag: a6000006-0002-0002-0002-000000000006
		sourceLineageTag: arrival_day_of_week
		summarizeBy: none
		sourceColumn: arrival_day_of_week

		changedProperty = Name

		annotation SummarizationSetBy = Automatic

	column 'Dwell Minutes'
		dataType: double
		lineageTag: a6000006-0002-0002-0002-000000000007
